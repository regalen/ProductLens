# JWT_SECRET: Secret key for signing JWT tokens.
# If not set, a random secret is generated on each server start (sessions won't survive restarts).
JWT_SECRET="change-this-to-a-random-secret"

# PORT: The port the server listens on (default: 3000, Docker default: 3446).
PORT=3446

# BASE_URL: The external URL used for generating public image links in exports.
# Set this to the URL where ProductLens is accessible from the internet.
BASE_URL="https://productlens.mydomain.com"

# CORS_ORIGIN: Allowed CORS origin (default: "*"). Set to your domain in production.
CORS_ORIGIN="https://your-domain.com"

# DATA_DIR: Override the persistent data directory (default: ./data, Docker: /data).
# DATA_DIR="/data"

# WORKSPACE_DIR: Temporary directory for in-flight image processing (default: DATA_DIR/workspace, Docker: /tmp/workspace).
# WORKSPACE_DIR="/tmp/workspace"
